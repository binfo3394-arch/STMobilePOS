<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base App Theme -->
    <style name="Theme.STMobilePOS" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#0f0f1a</item>
        <item name="android:statusBarColor">#0f0f1a</item>
        <item name="android:navigationBarColor">#0f0f1a</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">#6c63ff</item>
        <item name="colorPrimaryDark">#0f0f1a</item>
        <item name="colorAccent">#6c63ff</item>
    </style>

    <!-- Splash Theme (full screen) -->
    <style name="Theme.STMobilePOS.Splash" parent="Theme.STMobilePOS">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">#0f0f1a</item>
        <item name="android:statusBarColor">#0f0f1a</item>
        <item name="android:navigationBarColor">#0f0f1a</item>
    </style>

</resources>
